# =============================================================================
# NovaPay — environment template (keys must match ConfigService / process.env)
# Copy to `.env` and adjust. Remove comments if your loader dislikes them.
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3002

# --- PostgreSQL (required when DatabaseModule is imported) ---
DATABASE_WRITE_URL=postgresql://fintech:change-me-primary-strong@127.0.0.1:5432/fintech?sslmode=disable
DATABASE_READ_URL=postgresql://fintech:change-me-primary-strong@127.0.0.1:5433/fintech?sslmode=disable
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

# TypeORM CLI (`data-source.ts`): use compiled entities after `yarn build`
TYPEORM_DATASOURCE_USE_DIST=false

# --- JWT / auth (required when AuthModule is imported) ---
# Code reads these exact names — not JWT_SECRET / JWT_EXPIRES_IN.
JWT_ACCESS_SECRET=change-me-access-secret-use-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# --- RabbitMQ (required only if RabbitmqModule is imported in AppModule) ---
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
# Outbound client queue name (see rabbitmq.module.ts)
RABBITMQ_QUEUE=nova_pay.events
RABBITMQ_CONSUMER_QUEUE=nova_pay.consumers
RABBITMQ_PREFETCH=10

# --- Redis (optional — RedisService stays off if unset or empty) ---
REDIS_URL=

# =============================================================================
# Not read by current src/ — keep for future phases or external tooling only
# =============================================================================
# JWT_REFRESH_SECRET=        # unused: refresh tokens are opaque, not JWT in code
# RABBITMQ_QUEUE_NAME=       # wrong name; use RABBITMQ_QUEUE
# REDIS_HOST / REDIS_PORT    # unused; use REDIS_URL (e.g. redis://:pass@host:6379/0)
# RATE_LIMIT_*               # not wired in Nest yet
# LOG_*                      # Nest Logger not configured from env yet
